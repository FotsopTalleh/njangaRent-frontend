{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://njangarent-backend-production.up.railway.app/api/$1" },
    { "source": "/socket.io/(.*)", "destination": "https://njangarent-backend-production.up.railway.app/socket.io/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
